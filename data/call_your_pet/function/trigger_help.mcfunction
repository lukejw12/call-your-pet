tellraw @s ["",{"text":"[HELP]","color":"gray"}," ",{"text":"Call Your Pet","bold":true,"color":"gold"},"\n\n",{"text":"How it works","bold":true},"\n\n1. Tame a pet\n\n2. Give it a name with a name tag\n   (colored names and special characters supported)\n\n3. Hold any goat horn in your hand\n\n4. Sneak and look at the pet for 3 seconds\n\n5. Your horn is replaced with an enchanted horn\n\n6. Use the horn to teleport the pet to you\n   (works across dimensions!)\n\n",{"text":"Note:","bold":true}," Horns are player-locked. Others cannot use your horn or register your pets.\n\n",{"text":"Supported pets:","bold":true}," wolf, cat, parrot, horse, donkey, mule, camel, camel husk, happy ghast, nautilus, zombie nautilus, llama, trader llama, skeleton horse, zombie horse, allay, strider, snow golem, iron golem, fox, ocelot\n\n",{"text":"Uninstall:","bold":true}," ",{"text":"/function call_your_pet:uninstall","color":"yellow"}]